# Required
DATABASE_URL=postgresql://hone:hone@localhost:5432/hone?connection_limit=5&pool_timeout=10
SESSION_SECRET=change-me-32-chars-minimum
CSRF_SECRET=change-me-32-chars-minimum

# Required for OIDC (or set USE_LOCAL_AUTH_ONLY=true)
OIDC_ISSUER=https://authentik.example.com/application/o/hone/
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
USE_LOCAL_AUTH_ONLY=false

# Optional AI
AI_PROVIDER=ollama
AI_BASE_URL=http://localhost:11434
AI_MODEL=llama3.2

# Optional Storage (defaults to local filesystem)
STORAGE_PROVIDER=local
S3_BUCKET=
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Internal
PORT=3000
NODE_ENV=development
BOOTSTRAP_ADMIN_EMAIL=