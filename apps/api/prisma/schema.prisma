generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MODERATOR
  USER
}

enum TagCategory {
  MUSCLE_GROUP
  EQUIPMENT
  CATEGORY
  MODIFIER
}

enum ExerciseTagSource {
  EXTERNAL
  HEURISTIC
  LLM
  MANUAL
}

enum ExerciseTagStatus {
  CONFIRMED
  PENDING_REVIEW
  REJECTED
}

enum MesocyclusStatus {
  ACTIVE
  PENDING
  COMPLETED
  ARCHIVED
}

enum PlanSource {
  RULE_BASED
  AI_GENERATED
}

enum WorkoutLabel {
  A
  B
  C
}

enum WorkoutSessionStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum AiJobType {
  MESOCYCLUS
  FEEDBACK
}

enum AiJobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
  DEAD
}

enum AiJobPriority {
  NORMAL
  FEEDBACK
}

enum AiPromptType {
  MESOCYCLUS
  MESOCYCLUS_SIMPLIFIED
}

enum SafetyKeywordAction {
  WARN
  BLOCK
}

model User {
  id             String           @id @default(uuid())
  email          String           @unique
  oidcSub        String?          @unique @map("oidc_sub")
  passwordHash   String?          @map("password_hash")
  role           Role             @default(USER)
  goals          Json             @default("[]")
  constraints    Json             @default("{}")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  deletedAt      DateTime?        @map("deleted_at")
  sessions       Session[]
  equipmentPools EquipmentPool[]
  mesocycluses   Mesocyclus[]
  workoutSessions WorkoutSession[]
  bodyMetrics    BodyMetric[]
  aiJobs         AiJob[]
  exercises      Exercise[]       @relation("UserExercises")

  @@index([deletedAt])
  @@map("users")
}

model Session {
  id                      String    @id @default(uuid())
  userId                  String    @map("user_id")
  sessionHash             String    @unique @map("session_hash")
  expiresAt               DateTime  @map("expires_at")
  lastSeenAt              DateTime  @default(now()) @map("last_seen_at")
  workoutSessionStartedAt DateTime? @map("workout_session_started_at")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([expiresAt])
  @@map("sessions")
}

model UsedLogoutToken {
  id        String   @id @default(uuid())
  jti       String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([expiresAt])
  @@map("used_logout_tokens")
}

model EquipmentPool {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  name       String
  tags       String[]
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, deletedAt])
  @@map("equipment_pools")
}

model Exercise {
  id                String              @id @default(uuid())
  nameEn            String              @map("name_en")
  nameDe            String?             @map("name_de")
  descriptionEn     String?             @map("description_en") @db.Text
  imageUrl          String?             @map("image_url")
  imageAltText      String              @map("image_alt_text")
  suggestedRestSecs Int?                @map("suggested_rest_seconds")
  isGlobal          Boolean             @default(true) @map("is_global")
  ownerId           String?             @map("owner_id")
  contentHash       String?             @map("content_sha256")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  deletedAt         DateTime?           @map("deleted_at")
  owner             User?               @relation("UserExercises", fields: [ownerId], references: [id])
  tags              ExerciseTag[]
  embedding         ExerciseEmbedding?
  templateExercises WorkoutTemplateExercise[]
  exerciseLogs      ExerciseLog[]       @relation("LoggedExercise")
  substitutions     ExerciseLog[]       @relation("SubstitutedExercise")

  @@index([isGlobal, ownerId])
  @@map("exercises")
}

model Tag {
  id         String          @id @default(uuid())
  category   TagCategory
  value      String
  safetyBias String?         @map("safety_bias")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  deletedAt  DateTime?       @map("deleted_at")
  exercises  ExerciseTag[]

  @@unique([category, value])
  @@map("tags")
}

model ExerciseTag {
  exerciseId  String            @map("exercise_id")
  tagId       String            @map("tag_id")
  source      ExerciseTagSource @default(EXTERNAL)
  confidence  Float             @default(1)
  status      ExerciseTagStatus @default(CONFIRMED)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  deletedAt   DateTime?         @map("deleted_at")
  exercise    Exercise          @relation(fields: [exerciseId], references: [id])
  tag         Tag               @relation(fields: [tagId], references: [id])

  @@id([exerciseId, tagId])
  @@index([tagId])
  @@map("exercise_tags")
}

model ExerciseEmbedding {
  exerciseId String                    @id @map("exercise_id")
  embedding  Unsupported("vector(768)")?
  updatedAt  DateTime                  @updatedAt @map("updated_at")
  exercise   Exercise                  @relation(fields: [exerciseId], references: [id])

  @@map("exercise_embeddings")
}

model Mesocyclus {
  id              String            @id @default(uuid())
  userId          String            @map("user_id")
  status          MesocyclusStatus  @default(ACTIVE)
  planSource      PlanSource        @default(RULE_BASED) @map("plan_source")
  durationWeeks   Int               @default(4) @map("duration_weeks")
  workoutsPerWeek Int               @default(3) @map("workouts_per_week")
  sessionMinutes  Int               @default(30) @map("session_minutes")
  equipmentPoolId String?           @map("equipment_pool_id")
  nextTemplateId  String?           @map("next_template_id")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  deletedAt       DateTime?         @map("deleted_at")
  user            User              @relation(fields: [userId], references: [id])
  nextTemplate    WorkoutTemplate?  @relation("MesocyclusNextTemplate", fields: [nextTemplateId], references: [id])
  templates       WorkoutTemplate[] @relation("MesocyclusTemplates")
  workoutSessions WorkoutSession[]

  @@index([userId, status, deletedAt])
  @@map("mesocycluses")
}

model WorkoutTemplate {
  id                  String                    @id @default(uuid())
  mesocyclusId        String                    @map("mesocyclus_id")
  label               WorkoutLabel
  position            Int
  title               String?                   @db.VarChar(128)
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @updatedAt @map("updated_at")
  deletedAt           DateTime?                 @map("deleted_at")
  mesocyclus          Mesocyclus                @relation("MesocyclusTemplates", fields: [mesocyclusId], references: [id])
  nextForMesocycluses Mesocyclus[]              @relation("MesocyclusNextTemplate")
  exercises           WorkoutTemplateExercise[]
  workoutSessions     WorkoutSession[]

  @@unique([mesocyclusId, position])
  @@map("workout_templates")
}

model WorkoutTemplateExercise {
  id                String          @id @default(uuid())
  workoutTemplateId String          @map("workout_template_id")
  exerciseId        String          @map("exercise_id")
  position          Int
  sets              Int             @default(1)
  reps              Int?
  durationSecs      Int?            @map("duration_seconds")
  restSecsOverride  Int?            @map("rest_seconds_override")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  deletedAt         DateTime?       @map("deleted_at")
  workoutTemplate   WorkoutTemplate @relation(fields: [workoutTemplateId], references: [id])
  exercise          Exercise        @relation(fields: [exerciseId], references: [id])

  @@index([workoutTemplateId])
  @@map("workout_template_exercises")
}

model WorkoutSession {
  id           String               @id @default(uuid())
  userId       String               @map("user_id")
  mesocyclusId String?              @map("mesocyclus_id")
  templateId   String?              @map("template_id")
  status       WorkoutSessionStatus @default(ACTIVE)
  startedAt    DateTime             @default(now()) @map("started_at")
  completedAt  DateTime?            @map("completed_at")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  deletedAt    DateTime?            @map("deleted_at")
  user         User                 @relation(fields: [userId], references: [id])
  mesocyclus   Mesocyclus?          @relation(fields: [mesocyclusId], references: [id])
  template     WorkoutTemplate?     @relation(fields: [templateId], references: [id])
  exerciseLogs ExerciseLog[]

  @@index([userId, startedAt, id])
  @@map("workout_sessions")
}

model ExerciseLog {
  id                       String         @id @default(uuid())
  workoutSessionId         String         @map("workout_session_id")
  exerciseId               String         @map("exercise_id")
  substitutedForExerciseId String?        @map("substituted_for_exercise_id")
  position                 Int
  createdAt                DateTime       @default(now()) @map("created_at")
  updatedAt                DateTime       @updatedAt @map("updated_at")
  deletedAt                DateTime?      @map("deleted_at")
  workoutSession           WorkoutSession @relation(fields: [workoutSessionId], references: [id])
  exercise                 Exercise       @relation("LoggedExercise", fields: [exerciseId], references: [id])
  substitutedForExercise   Exercise?      @relation("SubstitutedExercise", fields: [substitutedForExerciseId], references: [id])
  setLogs                  SetLog[]

  @@index([workoutSessionId])
  @@map("exercise_logs")
}

model SetLog {
  id            String      @id @default(uuid())
  uuid          String      @unique
  exerciseLogId String      @map("exercise_log_id")
  setNr         Int         @map("set_nr")
  reps          Int?
  durationSecs  Int?        @map("duration_seconds")
  loggedAt      DateTime    @default(now()) @map("logged_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")
  exerciseLog   ExerciseLog @relation(fields: [exerciseLogId], references: [id])

  @@index([exerciseLogId])
  @@map("set_logs")
}

model AiJob {
  id             String            @id @default(uuid())
  userId         String            @map("user_id")
  type           AiJobType         @default(MESOCYCLUS)
  status         AiJobStatus       @default(PENDING)
  priority       AiJobPriority     @default(NORMAL)
  attemptCount   Int               @default(0) @map("attempt_count")
  maxAttempts    Int               @default(3) @map("max_attempts")
  workerId       String?           @map("worker_id")
  lockedUntil    DateTime?         @map("locked_until")
  heartbeatAt    DateTime?         @map("heartbeat_at")
  input          Json?
  output         Json?
  lastError      String?           @map("last_error") @db.Text
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  deletedAt      DateTime?         @map("deleted_at")
  user           User              @relation(fields: [userId], references: [id])
  generationLogs AiGenerationLog[]

  @@index([userId])
  @@index([status, priority, createdAt])
  @@map("ai_jobs")
}

model AiGenerationLog {
  id                String    @id @default(uuid())
  jobId             String    @map("job_id")
  provider          String
  modelId           String    @map("model_id")
  inputTokens       Int?      @map("input_tokens")
  outputTokens      Int?      @map("output_tokens")
  balanceScore      Int?      @map("balance_score")
  injectionDetected Boolean   @default(false) @map("injection_detected")
  fallbackUsed      Boolean   @default(false) @map("fallback_used")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")
  job               AiJob     @relation(fields: [jobId], references: [id])

  @@map("ai_generation_logs")
}

model AiPrompt {
  id        String       @id @default(uuid())
  type      AiPromptType
  version   Int
  content   String       @db.Text
  isActive  Boolean      @default(true) @map("is_active")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  deletedAt DateTime?    @map("deleted_at")

  @@unique([type, version])
  @@map("ai_prompts")
}

model SafetyKeyword {
  id         String              @id @default(uuid())
  keyword    String
  language   String
  action     SafetyKeywordAction @default(WARN)
  bodyRegion String?             @map("body_region")
  createdBy  String?             @map("created_by")
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")
  deletedAt  DateTime?           @map("deleted_at")

  @@unique([keyword, language])
  @@map("safety_keywords")
}

model BodyMetric {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  weightKg   Float?    @map("weight_kg")
  waistCm    Float?    @map("waist_cm")
  recordedAt DateTime  @default(now()) @map("recorded_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")
  user       User      @relation(fields: [userId], references: [id])

  @@index([userId, recordedAt])
  @@map("body_metrics")
}