{
  "name": "hone",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.2.15",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "cli": "PATH=\"$HOME/.bun/bin:$PATH\" bun run scripts/cli.ts",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "bun test",
    "typecheck": "PATH=\"$HOME/.bun/bin:$PATH\" bun run --cwd apps/api typecheck && PATH=\"$HOME/.bun/bin:$PATH\" bun run --cwd apps/web typecheck && PATH=\"$HOME/.bun/bin:$PATH\" bun run --cwd packages/shared typecheck",
    "dev:api": "PATH=\"$HOME/.bun/bin:$PATH\" bun run --cwd apps/api dev",
    "dev:web": "PATH=\"$HOME/.bun/bin:$PATH\" bun run --cwd apps/web dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "typescript": "^5.8.3"
  }
}
